rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Global Constants & Verification Helpers
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Pillar 2: Validation Blueprints with size matching (Anti-Update-Gap)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
        && data.keys().size() == 4
        && data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() >= 0 && data.displayName.size() <= 128
        && data.createdAt == request.time;
    }

    function isValidBookmark(data) {
      return data.keys().hasAll(['comicId', 'comicTitle', 'comicThumbnail', 'bookmarkedAt'])
        && data.keys().size() == 4
        && data.comicId is string && data.comicId.size() > 0 && data.comicId.size() <= 128
        && data.comicTitle is string && data.comicTitle.size() > 0 && data.comicTitle.size() <= 512
        && data.comicThumbnail is string && data.comicThumbnail.size() >= 0 && data.comicThumbnail.size() <= 2048
        && data.bookmarkedAt == request.time;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['comicId', 'comicTitle', 'comicThumbnail', 'chapterId', 'chapterName', 'updatedAt'])
        && data.keys().size() == 6
        && data.comicId is string && data.comicId.size() > 0 && data.comicId.size() <= 128
        && data.comicTitle is string && data.comicTitle.size() > 0 && data.comicTitle.size() <= 512
        && data.comicThumbnail is string && data.comicThumbnail.size() >= 0 && data.comicThumbnail.size() <= 2048
        && data.chapterId is string && data.chapterId.size() > 0 && data.chapterId.size() <= 128
        && data.chapterName is string && data.chapterName.size() > 0 && data.chapterName.size() <= 256
        && data.updatedAt == request.time;
    }

    // Phase 4 & Phase 6: Core fortress configurations
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) 
        && incoming().uid == existing().uid 
        && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(userId) && isValidId(userId);

      match /bookmarks/{comicId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(comicId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(comicId) 
          && isValidBookmark(incoming()) && incoming().comicId == comicId;
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(comicId) 
          && isValidBookmark(incoming()) && incoming().comicId == existing().comicId;
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(comicId);
      }

      match /history/{comicId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(comicId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(comicId) 
          && isValidHistory(incoming()) && incoming().comicId == comicId;
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(comicId) 
          && isValidHistory(incoming()) && incoming().comicId == existing().comicId;
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(comicId);
      }
    }
  }
}
